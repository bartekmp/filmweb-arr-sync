FILMWEB_USERNAME=your_filmweb_username

RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key
RADARR_ROOT_FOLDER=/movies
RADARR_QUALITY_PROFILE_ID=1 # Look up the correct ID in Radarr - Settings > Profiles
RADARR_ENABLED=true

SONARR_URL=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key
SONARR_ROOT_FOLDER=/tv
SONARR_QUALITY_PROFILE_ID=1 # Look up the correct ID in Sonarr - Settings > Profiles
# SONARR_LANGUAGE_PROFILE_ID=1  # Sonarr v3 only
SONARR_ENABLED=true

SYNC_INTERVAL_MINUTES=30
SYNC_DRY_RUN=false
STATE_FILE=/data/state.json
ADD_DELAY_SECONDS=5
