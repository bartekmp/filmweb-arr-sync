FILMWEB_USERNAME=your_filmweb_username

RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key
RADARR_ROOT_FOLDER=/movies
RADARR_QUALITY_PROFILE_ID=1 # Look up the correct ID in Radarr - Settings > Profiles
RADARR_ENABLED=true

SONARR_URL=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key
SONARR_ROOT_FOLDER=/tv
SONARR_QUALITY_PROFILE_ID=1 # Look up the correct ID in Sonarr - Settings > Profiles
# SONARR_LANGUAGE_PROFILE_ID=1  # Sonarr v3 only
SONARR_ENABLED=true

SYNC_INTERVAL_MINUTES=30  # ignored when SYNC_CRON is set
# SYNC_CRON=0 4 * * *    # optional: run at a fixed time instead of every N minutes
SYNC_DRY_RUN=false
STATE_FILE=/data/state.json
ADD_DELAY_SECONDS=5

# Batch queue — spreads additions over time to avoid overwhelming Radarr/Sonarr
# BATCH_QUEUE_ENABLED=true
# BATCH_SIZE=5
# BATCH_INTERVAL_MINUTES=10

# Telegram bot — send Filmweb/IMDb links to add titles on demand (daemon mode only)
# TELEGRAM_BOT_ENABLED=true
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-botfather
# TELEGRAM_ALLOWED_USER_IDS=11111111,22222222  # numeric user IDs allowed to use the bot; empty = everyone
# TELEGRAM_SEARCH_ON_ADD=true   # trigger a Radarr/Sonarr search immediately after adding
# TELEGRAM_POLL_TIMEOUT_SECONDS=30
